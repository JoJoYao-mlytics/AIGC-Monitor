{
  "name": "aigc-monitor",
  "version": "1.0.0",
  "private": true,
  "description": "AIGC functionality monitoring across multiple sites via Playwright",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "monitor": "node src/monitor.js",
    "monitor:gugu": "SITE_ID=gugu BASE_URL=https://www.gugu.fund/ node src/monitor.js",
    "monitor:gugu-article": "SITE_ID=gugu BASE_URL=https://school.gugu.fund/blog/invest-news/5288080656 node src/monitor.js",
    "monitor:gugu-config": "SITE_ID=gugu node src/monitor.js --config=config.gugu.json",
    "monitor:cmoney": "SITE_ID=cmoney BASE_URL=https://www.cmoney.tw/index.html node src/monitor.js",
    "monitor:cmoney-config": "SITE_ID=cmoney node src/monitor.js --config=config.cmoney.json",
    "monitor:bnext": "SITE_ID=bnext BASE_URL=https://www.bnext.com.tw/articles node src/monitor.js --config=config.bnext.json",
    "monitor:cnyes": "SITE_ID=cnyes BASE_URL=https://www.cnyes.com/ node src/monitor.js",
    "monitor:cnyes-config": "SITE_ID=cnyes node src/monitor.js --config=config.cnyes.json",
    "monitor:ucar": "SITE_ID=ucar BASE_URL=https://roadtest.u-car.com.tw/roadtest/articles node src/monitor.js",
    "monitor:ucar-config": "SITE_ID=ucar node src/monitor.js --config=config.ucar.json",
    "monitor:ucar-motor": "SITE_ID=ucar-motor BASE_URL=https://motor.u-car.com.tw/motor/articles node src/monitor.js",
    "monitor:ucar-motor-config": "SITE_ID=ucar-motor node src/monitor.js --config=config.ucar-motor.json",
    "monitor:ucar-news": "SITE_ID=ucar-news BASE_URL=https://news.u-car.com.tw/news/articles node src/monitor.js",
    "monitor:ucar-news-config": "SITE_ID=ucar-news node src/monitor.js --config=config.ucar-news.json",
    "monitor:ucar-am": "SITE_ID=ucar-am BASE_URL=https://am.u-car.com.tw/am node src/monitor.js",
    "monitor:ucar-am-config": "SITE_ID=ucar-am node src/monitor.js --config=config.ucar-am.json",
    "example:gugu": "node example.js",
    "example:cmoney": "node example-cmoney.js",
    "example:cnyes": "node example-cnyes.js",
    "example:ucar": "node example-ucar.js",
    "example:ucar-motor": "node example-ucar-motor.js",
    "example:ucar-news": "node example-ucar-news.js",
    "example:ucar-am": "node example-ucar-am.js",
    "start": "node src/monitor.js",
    "test": "playwright test --reporter=html",
    "test:gugu": "playwright test tests/gugu.spec.js --reporter=html",
    "test:cmoney": "playwright test tests/cmoney.spec.js --reporter=html",
    "test:bnext": "playwright test tests/bnext.spec.js --reporter=html",
    "test:cnyes": "playwright test tests/cnyes.spec.js --reporter=html",
    "test:ucar": "playwright test tests/ucar.spec.js --reporter=html",
    "test:ucar-motor": "playwright test tests/ucar-motor.spec.js --reporter=html",
    "test:ucar-news": "playwright test tests/ucar-news.spec.js --reporter=html",
    "test:ucar-am": "playwright test tests/ucar-am.spec.js --reporter=html",
    "test:all": "playwright test --reporter=html",
    "show-report": "playwright show-report",
    "setup": "npm install && npx playwright install chromium"
  },
  "dependencies": {
    "@playwright/test": "^1.55.0",
    "fs-extra": "^11.2.0",
    "moment": "^2.30.1",
    "playwright": "^1.55.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0"
  },
  "keywords": [
    "aigc",
    "monitoring",
    "playwright",
    "automation",
    "testing"
  ],
  "author": "BMad Team",
  "license": "MIT"
}
