{
  "baseUrl": "https://www.cmoney.tw/index.html",
  "timeouts": {
    "pageLoad": 60000,
    "findNews": 15000,
    "findAiSection": 10000,
    "findQuestion": 10000,
    "closeAds": 3000,
    "aiInitialWait": 5000,
    "aiContentWait": 60000,
    "aigcScriptWait": 30000,
    "aigcApiWait": 30000,
    "networkWait": 5000
  },
  "keywords": {
    "ai": [
      "你可能想知道",
      "你可能也想知道",
      "AIGC",
      "AI來解答",
      "AI解答",
      "智能問答",
      "Powered by Mlytics AI",
      "Answer / Powered by Mlytics AI"
    ]
  },
  "selectors": {
    "newsSection": [
      "text=每日精選",
      "text=精選文章",
      ".daily-picks",
      ".featured-articles"
    ],
    "newsLinks": [
      "a[href*='/notes/note-detail.aspx']:first-of-type",
      "a[href*='/notes/']:first-of-type",
      "a[href*='note-detail']:first-of-type",
      ".article-link:first-of-type"
    ],
    "aiSection": [
      "h2:has-text('你可能想知道')",
      "h2:has-text('你可能也想知道')",
      "heading:has-text('你可能想知道')",
      "heading:has-text('你可能也想知道')",
      "[data-testid*='aigc']",
      ".ai-qa-section"
    ],
    "aiQuestions": [
      "h2:has-text('你可能想知道') ~ * a[href*='aigc-note.cmoney.tw']:first-of-type",
      "h2:has-text('你可能也想知道') ~ * a[href*='aigc-note.cmoney.tw']:first-of-type",
      "a[href*='aigc-note.cmoney.tw']:first-of-type",
      "a[href*='/ai/answer']:first-of-type"
    ],
    "loadingTexts": [
      "text=解讀中",
      "text=載入中",
      "text=生成中",
      "text=Loading",
      "h5:has-text('解讀中')"
    ],
    "aiContent": [
      "h1:has-text('投資')",
      "h3:has-text('分析')",
      "text=Powered by Mlytics AI",
      ".ai-answer-content"
    ]
  },
  "apiEndpoints": {
    "questions_html": "https://api.aigc.mlytics.com/api/questions_html",
    "answer_html": "https://api.aigc.mlytics.com/api/answer_html",
    "aigc_app_js": "https://aigc-note.cmoney.tw/js/db_answer.min.js",
    "aigc_css": "https://aigc-note.cmoney.tw/css/aigc-answer.css",
    "questions_ajax": "https://api.aigc.mlytics.com/api/questions_ajax",
    "tracker": "https://api.aigc.mlytics.com/tracker",
    "member_html": "https://api.aigc.mlytics.com/api/member_html",
    "metadata_html": "https://api.aigc.mlytics.com/api/metadata_html"
  },
  "expectedConsoleMessages": [
    "AIGC 腳本加載完成",
    "🚀 Powered by Mlytics AI",
    "👉 Learn more or get a demo: https://www.mlytics.com/lp/get-a-demo/"
  ],
  "profiles": {
    "cmoney": {
      "name": "CMoney 投資網誌",
      "baseUrl": "https://www.cmoney.tw/index.html",
      "keywords": {
        "ai": [
          "你可能想知道",
          "AIGC",
          "Powered by Mlytics AI"
        ]
      },
      "selectors": {
        "newsLinks": [
          "a[href*='/notes/']:first-of-type"
        ],
        "aiSection": [
          "h2:has-text('你可能想知道')"
        ],
        "aiQuestions": [
          "a[href*='aigc-note.cmoney.tw']:first-of-type"
        ]
      },
    "apiEndpoints": {
      "metadata_html": "https://api.aigc.mlytics.com/api/metadata_html",
      "answer_html": "https://api.aigc.mlytics.com/api/answer_html",
      "questions_html": "https://api.aigc.mlytics.com/api/questions_html",
      "member_html": "https://api.aigc.mlytics.com/api/member_html",
      "questions_ajax": "https://api.aigc.mlytics.com/api/questions_ajax"
    }
    }
  }
}