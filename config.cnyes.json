    "pageLoad": 60000,
    "findNews": 30000,
    "findAiSection": 20000,
    "findQuestion": 20000,
    "closeAds": 5000,
    "aiInitialWait": 5000,
    "aiContentWait": 60000,
    "aigcScriptWait": 30000,
    "aigcApiWait": 30000,
    "networkWait": 5000
