      "a[href*='/aigc/answer']:first-of-type",
      "a[href*='news.cnyes.com/news/aigc/answer']:first-of-type"
    ],
    "loadingTexts": [
      "text=載入中",
      "text=解讀中",
      "text=生成中",
      "text=Loading"
